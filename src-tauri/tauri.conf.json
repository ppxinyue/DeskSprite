{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeskCat",
  "version": "0.1.0",
  "identifier": "com.deskcat.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: asset: http://asset.localhost; media-src 'self' data: asset: http://asset.localhost; connect-src https://api.openai.com https://api.anthropic.com https://api.groq.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/assets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

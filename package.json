{
  "name": "deskcat",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "native:build": "node scripts/build-panel-key-fix.mjs",
    "electron:dev": "pnpm native:build && concurrently -k \"pnpm dev\" \"wait-on tcp:127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "electron:start": "pnpm native:build && node scripts/verify-pet-assets.mjs && electron .",
    "build": "tsc -b && vite build && node scripts/optimize-pet-assets.mjs && node scripts/prune-dist-assets.mjs && node scripts/verify-pet-assets.mjs",
    "electron:build": "pnpm native:build && pnpm build && electron-builder",
    "electron:build:mac": "pnpm native:build && pnpm build && electron-builder --mac dmg --x64 --arm64 --publish never",
    "lint": "eslint .",
    "test:timeline": "node --test src/lib/timelineRecorder.test.ts src/lib/timelineView.test.ts src/lib/db.timeline.test.ts src/lib/cloudSyncScheduler.test.ts",
    "test:ai": "node --test src/features/ai/systemKnowledgeLogic.test.ts",
    "test:chat": "node --test src/features/chat/sendShortcut.test.ts src/features/chat/dropImageHandoff.test.ts src/features/chat/dragImageFiles.test.ts src/features/pet/contextMenuAction.test.ts src/features/pet/animations.test.ts src/lib/apiKeyStorage.test.ts",
    "test:startup": "node --test src/lib/startupTheme.test.ts src/lib/platformSupport.test.ts electron/windowLifecycle.test.cjs electron/codingStatus.test.cjs electron/welcomePermissionPrompt.test.cjs electron/secureKeyStore.test.cjs electron/windowsActivity.test.cjs electron/windowsProcesses.test.cjs",
    "test": "pnpm test:timeline && pnpm test:ai && pnpm test:chat && pnpm test:startup",
    "preview": "vite preview"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@remotion/cli": "4.0.459",
    "@remotion/gif": "4.0.459",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "ffmpeg-static": "^5.3.0",
    "globals": "^17.5.0",
    "remotion": "4.0.459",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.3",
    "zod": "4.3.6"
  },
  "build": {
    "appId": "com.deskcat.app",
    "productName": "DeskCat",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "electron/native/*.node"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ppxinyue",
        "repo": "DeskCat"
      }
    ],
    "files": [
      "dist/**",
      "electron/**",
      "!electron/**/*.test.cjs",
      "!electron/**/*.test.js",
      "!node_modules/**/*.map",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.d.cts",
      "!node_modules/**/*.d.mts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/changelog*",
      "!node_modules/@napi-rs/canvas-darwin-*",
      "!node_modules/@napi-rs/canvas-darwin-*/**",
      "!**/node_modules/@napi-rs/canvas-darwin-*",
      "!**/node_modules/@napi-rs/canvas-darwin-*/**",
      "src-tauri/icons/32x32.png",
      "src-tauri/icons/icon.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "identity": "-",
      "icon": "src-tauri/icons/icon.icns",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "DeskCat 使用自动化权限识别当前前台应用和窗口状态，并仅在你询问日程、会议、待办或提醒时读取日历和提醒事项；不会修改这些数据。",
        "NSAccessibilityUsageDescription": "DeskCat 使用辅助功能权限识别当前窗口、全屏和屏幕共享状态，让灵宠悬浮显示与专注提醒更稳定；不会读取键盘输入或替你操作其他 App。",
        "NSCalendarsUsageDescription": "DeskCat reads upcoming calendar events only when System Knowledge Base is enabled and relevant to your question.",
        "NSRemindersUsageDescription": "DeskCat reads upcoming reminders only when System Knowledge Base is enabled and relevant to your question.",
        "NSLocationWhenInUseUsageDescription": "DeskCat uses your approximate location to answer weather questions in System Knowledge Base."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "src-tauri/icons/icon.ico"
    }
  }
}
